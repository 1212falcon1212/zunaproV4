// Tenant database schema — tenant_{slug}
// Each tenant gets their own database with this schema
// Multi-language fields use Json (JSONB) with structure: {"en": "...", "tr": "...", "de": "..."}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_TENANT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/tenant-client"
}

model Product {
  id             String   @id @default(uuid())
  name           Json     // {"en": "Blue T-Shirt", "tr": "Mavi Tisort"}
  slug           String   @unique
  description    Json?    // {"en": "...", "tr": "..."}
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(10, 2)
  sku            String?
  stock          Int      @default(0)
  images         Json     @default("[]") // string[] as JSONB
  variants       Json     @default("[]") // ProductVariant[] as JSONB
  categoryId     String?  @map("category_id")
  seoMeta        Json?    @map("seo_meta") // {"en": {title, description}, "tr": {title, description}}
  status         String   @default("draft") // 'draft' | 'active' | 'archived'
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category Category? @relation(fields: [categoryId], references: [id])

  @@map("products")
}

model Category {
  id        String  @id @default(uuid())
  name      Json    // {"en": "Furniture", "tr": "Mobilya"}
  slug      String  @unique
  image     String?
  parentId  String? @map("parent_id")
  sortOrder Int     @default(0) @map("sort_order")
  seoMeta   Json?   @map("seo_meta") // {"en": {title, description}, "tr": {title, description}}

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Order {
  id              String   @id @default(uuid())
  orderNumber     String   @unique @map("order_number")
  customerId      String?  @map("customer_id")
  status          String   @default("pending") // 'pending' | 'processing' | 'shipped' | 'delivered' | 'cancelled'
  totalAmount     Decimal  @db.Decimal(10, 2) @map("total_amount")
  currency        String   @default("TRY")
  exchangeRate    Decimal? @db.Decimal(10, 6) @map("exchange_rate") // rate at time of order
  items           Json     @default("[]") // OrderItem[] as JSONB
  shippingAddress Json?    @map("shipping_address") // Address as JSONB
  billingAddress  Json?    @map("billing_address") // Address as JSONB
  locale          String   @default("tr") // locale used when order was placed
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("orders")
}

model Customer {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  phone     String?
  locale    String   @default("tr") // customer preferred locale
  addresses Json     @default("[]") // Address[] as JSONB
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("customers")
}

model Page {
  id          String   @id @default(uuid())
  title       Json     // {"en": "About Us", "tr": "Hakkimizda"}
  slug        String   @unique
  content     Json?    // {"en": "<p>...</p>", "tr": "<p>...</p>"}
  template    String   @default("default") // 'default' | 'contact' | 'faq'
  isPublished Boolean  @default(false) @map("is_published")
  seoMeta     Json?    @map("seo_meta") // {"en": {title, description}, "tr": {title, description}}
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value Json   @default("{}") // JSONB
  group String @default("general")

  @@map("settings")
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  url       String
  mimeType  String   @map("mime_type")
  size      Int
  alt       Json?    // {"en": "Product image", "tr": "Urun gorseli"}
  createdAt DateTime @default(now()) @map("created_at")

  @@map("media")
}
