// Tenant database schema — tenant_{slug}
// Each tenant gets their own database with this schema
// Multi-language fields use Json (JSONB) with structure: {"en": "...", "tr": "...", "de": "..."}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_TENANT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/tenant-client"
}

model Product {
  id             String   @id @default(uuid())
  name           Json     // {"en": "Blue T-Shirt", "tr": "Mavi Tisort"}
  slug           String   @unique
  description    Json?    // {"en": "...", "tr": "..."}
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(10, 2)
  sku            String?
  barcode        String?
  weight         Decimal? @db.Decimal(10, 2)
  stock          Int      @default(0)
  images         Json     @default("[]") // string[] as JSONB
  variants       Json     @default("[]") // ProductVariant[] as JSONB
  categoryId     String?  @map("category_id")
  seoMeta        Json?    @map("seo_meta") // {"en": {title, description}, "tr": {title, description}}
  status         String   @default("draft") // 'draft' | 'active' | 'archived'
  isFeatured     Boolean  @default(false) @map("is_featured")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category              Category?                      @relation(fields: [categoryId], references: [id])
  marketplaceListings   MarketplaceListing[]
  marketplaceAttributes ProductMarketplaceAttribute[]

  @@map("products")
}

model Category {
  id        String  @id @default(uuid())
  name      Json    // {"en": "Furniture", "tr": "Mobilya"}
  slug      String  @unique
  image      String?
  parentId   String?  @map("parent_id")
  sortOrder  Int      @default(0) @map("sort_order")
  isFeatured  Boolean  @default(false) @map("is_featured")
  description Json?    // {"en": "<html>...", "tr": "<html>..."} SEO description
  seoMeta     Json?    @map("seo_meta") // {"en": {title, description}, "tr": {title, description}}

  parent              Category?                    @relation("CategoryTree", fields: [parentId], references: [id])
  children            Category[]                   @relation("CategoryTree")
  products            Product[]
  marketplaceMappings MarketplaceCategoryMapping[]

  @@map("categories")
}

model Order {
  id              String   @id @default(uuid())
  orderNumber     String   @unique @map("order_number")
  customerId      String?  @map("customer_id")
  status          String   @default("pending") // 'pending' | 'confirmed' | 'processing' | 'shipped' | 'delivered' | 'cancelled' | 'refunded'
  totalAmount     Decimal  @db.Decimal(10, 2) @map("total_amount")
  subtotalAmount  Decimal  @default(0) @db.Decimal(10, 2) @map("subtotal_amount")
  taxAmount       Decimal  @default(0) @db.Decimal(10, 2) @map("tax_amount")
  discountAmount  Decimal  @default(0) @db.Decimal(10, 2) @map("discount_amount")
  shippingCost    Decimal  @default(0) @db.Decimal(10, 2) @map("shipping_cost")
  currency        String   @default("TRY")
  exchangeRate    Decimal? @db.Decimal(10, 6) @map("exchange_rate") // rate at time of order
  items           Json     @default("[]") // OrderItem[] as JSONB
  shippingAddress Json?    @map("shipping_address") // Address as JSONB
  billingAddress  Json?    @map("billing_address") // Address as JSONB
  paymentMethod   String?  @map("payment_method") // stripe, iyzico, bank_transfer
  paymentStatus   String   @default("pending") @map("payment_status") // pending, paid, failed, refunded
  paymentRef      String?  @map("payment_ref") // gateway reference ID
  trackingNumber  String?  @map("tracking_number")
  shippingMethod  String?  @map("shipping_method") // yurtici, aras, mng
  notes           String?
  locale          String   @default("tr") // locale used when order was placed
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("orders")
}

model Customer {
  id           String    @id @default(uuid())
  email        String    @unique
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  passwordHash String?   @map("password_hash")
  isGuest      Boolean   @default(false) @map("is_guest")
  lastLoginAt  DateTime? @map("last_login_at")
  locale       String    @default("tr") // customer preferred locale
  addresses    Json      @default("[]") // Address[] as JSONB
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  orders Order[]

  @@map("customers")
}

model Page {
  id          String   @id @default(uuid())
  title       Json     // {"en": "About Us", "tr": "Hakkimizda"}
  slug        String   @unique
  content     Json?    // PageContent format: { version: 1, blocks: Block[] }
  template    String   @default("default") // 'default' | 'contact' | 'faq'
  isPublished Boolean  @default(false) @map("is_published")
  seoMeta     Json?    @map("seo_meta") // {"en": {title, description}, "tr": {title, description}}
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value Json   @default("{}") // JSONB
  group String @default("general")

  @@map("settings")
}

model GlobalSection {
  id        String   @id @default(uuid())
  type      String   @unique // 'header' | 'footer'
  content   Json     // Block tree (PageContent format)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("global_sections")
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  url       String
  mimeType  String   @map("mime_type")
  size      Int
  alt       Json?    // {"en": "Product image", "tr": "Urun gorseli"}
  createdAt DateTime @default(now()) @map("created_at")

  @@map("media")
}

model Menu {
  id        String   @id @default(uuid())
  name      Json     // {"en": "Main Menu", "tr": "Ana Menu"}
  slug      String   @unique
  location  String   @default("header") // header | top-header | footer | mobile
  items     Json     @default("[]") // MenuItem[] nested JSONB
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("menus")
}

model BlogPost {
  id            String    @id @default(uuid())
  title         Json      // {"en": "...", "tr": "..."}
  slug          String    @unique
  excerpt       Json?     // {"en": "...", "tr": "..."}
  content       Json?     // {"en": "<html>...", "tr": "<html>..."}
  featuredImage String?   @map("featured_image")
  author        String?
  category      String?   // simple string tag like "Technology", "News"
  tags          Json      @default("[]") // string[] as JSONB
  status        String    @default("draft") // 'draft' | 'published'
  publishedAt   DateTime? @map("published_at")
  seoMeta       Json?     @map("seo_meta")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("blog_posts")
}

// ==================== Marketplace Models ====================

model MarketplaceIntegration {
  id          String   @id @default(uuid())
  marketplace String   @unique // 'trendyol' | 'hepsiburada' | 'ciceksepeti'
  credentials Json     // { supplierId, apiKey, apiSecret } or { apiKey } (CS)
  isActive    Boolean  @default(true) @map("is_active")
  settings    Json?    // marketplace-specific settings
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("marketplace_integrations")
}

model MarketplaceCategory {
  id                    String  @id @default(uuid())
  marketplace           String
  marketplaceCategoryId String  @map("marketplace_category_id")
  categoryName          String  @map("category_name")
  parentId              String? @map("parent_id")
  attributes            Json?   // cached category attributes from marketplace API

  @@unique([marketplace, marketplaceCategoryId])
  @@map("marketplace_categories")
}

model MarketplaceCategoryMapping {
  id                    String   @id @default(uuid())
  marketplace           String
  localCategoryId       String   @map("local_category_id")
  marketplaceCategoryId String   @map("marketplace_category_id")
  attributeMapping      Json?    @map("attribute_mapping") // saved attribute defaults

  localCategory Category @relation(fields: [localCategoryId], references: [id])

  @@unique([marketplace, localCategoryId])
  @@map("marketplace_category_mappings")
}

model MarketplaceListing {
  id                   String    @id @default(uuid())
  marketplace          String
  productId            String    @map("product_id")
  marketplaceProductId String?   @map("marketplace_product_id")
  batchId              String?   @map("batch_id")
  status               String    @default("pending") // pending, sent, approved, rejected, error
  lastSyncedAt         DateTime? @map("last_synced_at")
  syncData             Json?     @map("sync_data")
  errorMessage         String?   @map("error_message")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])

  @@unique([marketplace, productId])
  @@map("marketplace_listings")
}

model SyncLog {
  id          String   @id @default(uuid())
  marketplace String
  action      String   // 'import', 'export', 'price_sync', 'stock_sync', 'category_sync'
  status      String   // 'started', 'completed', 'failed'
  details     Json?
  itemCount   Int      @default(0) @map("item_count")
  errorCount  Int      @default(0) @map("error_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("sync_logs")
}

model MarketplaceBrand {
  id                 String @id @default(uuid())
  marketplace        String
  marketplaceBrandId String @map("marketplace_brand_id")
  brandName          String @map("brand_name")

  @@unique([marketplace, marketplaceBrandId])
  @@map("marketplace_brands")
}

model ProductMarketplaceAttribute {
  id            String  @id @default(uuid())
  productId     String  @map("product_id")
  marketplace   String
  attributeId   String  @map("attribute_id")
  attributeName String  @map("attribute_name")
  value         String
  valueId       String? @map("value_id")
  variantIndex  Int     @default(-1) @map("variant_index") // -1 = product-level, 0+ = variant index

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplace, attributeId, variantIndex])
  @@map("product_marketplace_attributes")
}
