{
  "name": "@zunapro/themes",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./templates": {
      "types": "./src/templates/index.ts",
      "default": "./src/templates/index.ts"
    },
    "./seeds": {
      "types": "./src/seeds/index.ts",
      "default": "./src/seeds/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zunapro/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
